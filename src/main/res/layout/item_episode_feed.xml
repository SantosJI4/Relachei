<?xml version="1.0" encoding="utf-8"?>
<!-- Card de episódio no feed (estilo TikTok, tela cheia) -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- === VIDEO VIEW (tela cheia, toca inline) === -->
    <VideoView
        android:id="@+id/vv_episode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible" />

    <!-- === THUMBNAIL DE FUNDO (full screen) === -->
    <ImageView
        android:id="@+id/iv_thumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Capa do episódio" />

    <!-- Gradiente no topo (suaviza transição) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="top"
        android:background="@drawable/gradient_feed_top" />

    <!-- Gradiente embaixo (legibilidade do texto) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_feed_bottom" />

    <!-- === OVERLAY DE BLOQUEADO === -->
    <View
        android:id="@+id/overlay_locked"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone" />

    <!-- === CENTRO: botão play / cadeado === -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center">

        <!-- Círculo de fundo -->
        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/shape_circle_dark"
            android:alpha="0.6" />

        <!-- Ícone play -->
        <ImageView
            android:id="@+id/iv_play_btn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play"
            android:contentDescription="Reproduzir" />

        <!-- Ícone cadeado (por cima do play quando bloqueado) -->
        <ImageView
            android:id="@+id/iv_lock_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_lock"
            android:visibility="gone"
            android:contentDescription="Bloqueado" />

    </FrameLayout>

    <!-- === LADO DIREITO: Botões de ação (like, share) === -->
    <LinearLayout
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Like -->
        <ImageView
            android:id="@+id/iv_like_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_heart_outline"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Curtir" />

        <TextView
            android:id="@+id/tv_like_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:text="0" />

        <!-- Compartilhar -->
        <ImageView
            android:id="@+id/iv_share_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_share"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Compartilhar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:text="Compartilhar" />

    </LinearLayout>

    <!-- === INFERIOR ESQUERDO: Informações do episódio === -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="72dp"
        android:orientation="vertical">

        <!-- País de origem -->
        <TextView
            android:id="@+id/tv_country"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:text="🇯🇵 Japão" />

        <!-- Título da novela -->
        <TextView
            android:id="@+id/tv_novela_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Amor em Tóquio" />

        <!-- Episódio e duração -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tv_episode_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:text="Ep. 1 • 23:00" />

            <!-- Tag GRÁTIS -->
            <TextView
                android:id="@+id/tv_free_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/shape_badge_red"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="GRÁTIS"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Custo em moedas -->
            <TextView
                android:id="@+id/tv_coin_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/shape_badge_gold"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="🪙 2"
                android:textColor="@android:color/black"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Descrição curta -->
        <TextView
            android:id="@+id/tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="Descrição do episódio aparece aqui..." />

    </LinearLayout>

</FrameLayout>
