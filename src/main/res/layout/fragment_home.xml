<?xml version="1.0" encoding="utf-8"?>
<!-- Fragment Home: ViewPager2 vertical estilo TikTok + balança de moedas no topo -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Feed vertical full-screen -->
    <ListView
        android:id="@+id/feed_list_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@null"
        android:dividerHeight="0dp" />

    <!-- HUD topo: saldo de moedas -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_overlay"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tv_coin_balance_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/coin_color"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="🪙 0" />

    </LinearLayout>

    <!-- Logo NoveFlix no canto superior esquerdo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="48dp"
        android:layout_marginStart="16dp"
        android:text="NoveFlix"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

</FrameLayout>
