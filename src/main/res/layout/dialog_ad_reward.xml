<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog: escolha de tipo de anúncio para ganhar moedas -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/shape_bottom_sheet"
    android:padding="24dp">

    <!-- Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:text="Ganhar Moedas Grátis"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Assista um anúncio e ganhe moedas para desbloquear episódios!"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <!-- Anúncio rápido -->
    <LinearLayout
        android:id="@+id/btn_short_ad"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/shape_card_dark"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play"
            android:contentDescription="Anúncio rápido" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anúncio Rápido"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~30 segundos"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+1 🪙"
            android:textColor="@color/coin_color"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Anúncio longo -->
    <LinearLayout
        android:id="@+id/btn_long_ad"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/shape_card_vip_popular"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_crown"
            android:contentDescription="Anúncio longo" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anúncio Completo ✨"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~60 segundos • Mais recompensa"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+3 🪙"
            android:textColor="@color/coin_color"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Cancelar -->
    <Button
        android:id="@+id/btn_ad_cancel"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/transparent"
        android:text="Agora não"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:stateListAnimator="@null" />

</LinearLayout>
