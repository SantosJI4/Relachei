<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:background="@color/bg_surface"
    android:clickable="true"
    android:focusable="true">

    <!-- Número do episódio -->
    <TextView
        android:id="@+id/tv_ep_number_badge"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:background="@color/bg_elevated"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:text="1" />

    <!-- Informações do episódio -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/tv_ep_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Título do Episódio" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp">

            <TextView
                android:id="@+id/tv_ep_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:text="00:00" />

            <TextView
                android:id="@+id/tv_ep_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:text="GRÁTIS" />

        </LinearLayout>

    </LinearLayout>

    <!-- Botão de play -->
    <ImageView
        android:id="@+id/iv_play_ep"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_play"
        android:background="@drawable/shape_circle_dark"
        android:padding="10dp"
        android:contentDescription="Assistir"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
