<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema base NoveFlix: Preto + Vermelho -->
    <style name="Theme.NoveFlix" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/red_primary</item>
        <item name="colorPrimaryDark">@color/red_dark</item>
        <item name="colorAccent">@color/red_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/nav_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Splash sem barra -->
    <style name="Theme.NoveFlix.Splash" parent="Theme.NoveFlix">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <!-- Player fullscreen -->
    <style name="Theme.NoveFlix.Player" parent="Theme.NoveFlix">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- Botão Vermelho Primário -->
    <style name="Widget.NoveFlix.Button.Red" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/red_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Botão Dourado VIP -->
    <style name="Widget.NoveFlix.Button.Gold" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/gold_vip</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Botão Outline -->
    <style name="Widget.NoveFlix.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/red_primary</item>
        <item name="android:textColor">@color/red_primary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Card escuro -->
    <style name="Widget.NoveFlix.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>

</resources>
